# Copy to .env and fill in. Used for local testing only.

# --- LLM ---
LLM_PROVIDER=openai            # openai | gemini | custom
LLM_API_KEY=
LLM_MODEL=                     # optional; provider default used if blank
LLM_BASE_URL=                  # only needed when LLM_PROVIDER=custom
TOP_N=15

# --- Email (SMTP). Leave blank to print to stdout instead. ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_STARTTLS=true
EMAIL_FROM=
EMAIL_TO=
